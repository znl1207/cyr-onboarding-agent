APP_NAME=cyr-onboarding-agent
PORT=3000
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ADMIN_CHAT_ID=your_admin_chat_id
DATABASE_URL=postgresql://username:password@host:5432/dbname
ENCRYPTION_KEY=replace_with_a_secure_random_key

# CreditRepairCloud
CRC_API_KEY=your_crc_api_key
CRC_SECRET_KEY=your_crc_secret_key
CRC_MODE=legacy_xml
CRC_BASE_URL=https://app.creditrepaircloud.com
CRC_CREATE_CLIENT_PATH=/api/lead/insertRecord
CRC_CLIENT_STATUS=Client
CRC_REFERRED_BY_FIRST_NAME=Zayn
CRC_REFERRED_BY_LAST_NAME=Lakhani
CRC_PORTAL_ACCESS_ENABLED=true
CRC_SEND_PORTAL_PASSWORD_EMAIL=true
CRC_USE_PLAYWRIGHT_FALLBACK=false

# Playwright CRC fallback (optional)
PLAYWRIGHT_HEADLESS=true
CRC_PLAYWRIGHT_LOGIN_URL=
CRC_PLAYWRIGHT_USERNAME=
CRC_PLAYWRIGHT_PASSWORD=

# GoHighLevel
GHL_API_KEY=your_ghl_api_key
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_CONTACT_PATH=/contacts/
GHL_OPPORTUNITY_PATH=/opportunities/
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
GHL_ONBOARDING_STAGE_ID=

# Twilio (optional for approval SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_APPROVAL_TEMPLATE=You're all set! Disputes will be sent out within the next 24 hours. Any questions? Reach us at 954-770-3006
